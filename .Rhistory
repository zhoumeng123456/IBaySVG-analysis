result <- IBaySVG(spelist = spelist,c_alpha = c_alpha,num_cores = 10)
View(result)
# Print key outputs:
# 1. Posterior mean probabilities after maximization
print(result[[2]])
# 2. the identified SV genes
print(result[[4]])
# Print key outputs:
# 1. Posterior mean probabilities after maximization
print(result[[2]])
result <- IBaySVG(spelist = spelist,c_alpha = c_alpha,num_cores = 10,max_iter=300)
# Print key outputs:
# 1. Posterior mean probabilities after maximization
print(result[[2]])
# 2. the identified SV genes
print(result[[4]])
# 3. the posterior mean of parameters
names(result[[5]][[1]])
