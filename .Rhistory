##Layout and save
for(i in seq(pattern_domain)){
combined_plot <-
(wrap_elements(p_total_list[[1]][[i]] | p_total_list[[2]][[i]] | p_total_list[[3]][[i]]) +
labs(tag = "A") +
theme(
plot.tag = element_text(size = 14, face = "bold", margin = margin(0)),
plot.tag.position = c(0.01, 1)
)) /
(wrap_elements(p_total_list[[4]][[i]] | p_total_list[[6]][[i]] | p_total_list[[5]][[i]]) +
labs(tag = "B") +
theme(
plot.tag = element_text(size = 14, face = "bold", margin = margin(0)),
plot.tag.position = c(0.01, 1)
)) /
(wrap_elements(p_total_list[[7]][[i]]) +
labs(tag = "C") +
theme(
plot.tag = element_text(size = 14, face = "bold", margin = margin(0)),
plot.tag.position = c(0.01, 1)
)) +
plot_layout(
heights = c(1, 1, 1.2),
guides = "collect"
) &
theme(
legend.position = "bottom",
plot.title = element_text(size = 20, face = "bold", hjust = 0.5)
)
plot(combined_plot)
ggsave(paste0("/Users/zhoum/Desktop/simulation_sensi_",pattern_domain[i],".png"), plot = combined_plot, width = 10, height = 10, dpi = 300)
}
