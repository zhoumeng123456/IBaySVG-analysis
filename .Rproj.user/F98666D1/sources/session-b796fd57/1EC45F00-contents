plot_total_index_point <- function(data,legend_position="none",select_index,title = "",x_title = "",y_title = "Value") {
  
  ggplot(
    data %>%
      filter(index == select_index) %>%
      mutate(
        method = factor(
          method,
          levels = c(
            "Proposed","DESpace",
            "SPARK-AVE","SPARKX-AVE","HEARTSVG-AVE","nnSVG-AVE","spVC-AVE",
            "SPARK-Union","SPARKX-Union","HEARTSVG-Union","nnSVG-Union","spVC-Union",
            "SPARK-Inter","SPARKX-Inter","HEARTSVG-Inter","nnSVG-Inter","spVC-Inter",
            "SPARK-Cauchy","SPARKX-Cauchy","HEARTSVG-Cauchy","nnSVG-Cauchy","spVC-Cauchy",
            "SPARK-HMP","SPARKX-HMP","HEARTSVG-HMP","nnSVG-HMP","spVC-HMP",
            "SPARK-PASTE","SPARKX-PASTE","HEARTSVG-PASTE","nnSVG-PASTE","spVC-PASTE",
            "GASTON-AVE","GASTON-Union","GASTON-Inter","GASTON-PASTE",
            "StarTrail-AVE","StarTrail-Union","StarTrail-Inter","StarTrail-PASTE"
          )
        ),
        method_group = case_when(
          method %in% c("Proposed", "DESpace") ~ "Multi",
          grepl("AVE", method) ~ "AVE",
          grepl("Union", method) ~ "Union",
          grepl("Inter", method) ~ "Inter",
          grepl("Cauchy", method) ~ "Cauchy",
          grepl("HMP", method) ~ "HMP",
          grepl("PASTE", method) ~ "PASTE",
          TRUE ~ "Other"
        ),
        method_group = factor(
          method_group,
          levels = c("Multi","AVE","Union","Inter","Cauchy","HMP","PASTE")
        )
      ),
    aes(
      x = method_group,
      y = value,
      color = method
    )
  ) +
    facet_grid(. ~ data, scales = "free_x", space = "free_x") +
    geom_point(
      position = position_jitter(width = 0.25),
      size = 1,
      alpha = 0.9
    ) +
    labs(
      title = title,
      x = x_title,
      y = y_title
    ) +
    theme_minimal() +
    theme(
      plot.margin = margin(0.2, 0.2, 0.2, 0.2),
      plot.title = element_text(size = 10, face = "bold"),
      axis.text.y = element_text(size = 8),
      axis.title.y = element_text(size = 8),
      axis.text.x = element_text(size = 8),
      axis.ticks.x = element_line(),
      legend.position = legend_position,
      legend.title = element_blank(),
      legend.text = element_text(size = 8),
      strip.text = element_text(size = 8),
      panel.spacing = unit(0.5, "lines")
    )+ guides(
      color = guide_legend(
        override.aes = list(
          shape = 15,   # 方块
          size  = 4,    # legend 里块状大小
          alpha = 1
        )
      )
    )+
    scale_color_manual(values = custom_colors)
  
}


