                      grepl("Union", method) ~ "Union",
                      grepl("Inter", method) ~ "Inter",
                      grepl("Cauchy", method) ~ "Cauchy",
                      grepl("HMP", method) ~ "HMP",
                      grepl("PASTE", method) ~ "PASTE",
                      TRUE ~ "Other"
                    ),
                    method_group = factor(method_group, levels = c("Multi", "AVE", "Union", "Inter", "Cauchy","HMP","PASTE")),
