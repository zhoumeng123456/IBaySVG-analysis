          fp_paste=sum(index>500,na.rm=TRUE)/4500
          
          for(result_type in c("F1","precision","recall","FPR")){
            if(result_type=="F1"){
              result_uni <- 2 * uni_tpvalue / (1 + 9 * uni_fpvalue + uni_tpvalue)
              result_inter <- 2 * inter_tpvalue / (1 + 9 * inter_fpvalue + inter_tpvalue)
              result_mean <- 2 * mean_tpvalue / (1 + 9 * mean_fpvalue + mean_tpvalue)
              result_paste <- 2 * tp_paste / (1 + 9 * fp_paste + tp_paste)
              
            }else if(result_type=="precision"){
              result_uni=uni_tpvalue/(uni_tpvalue+9*uni_fpvalue)
              result_inter=inter_tpvalue/(inter_tpvalue+9*inter_fpvalue)
              result_mean=mean_tpvalue/(mean_tpvalue+9*mean_fpvalue)
              result_paste=tp_paste/(tp_paste+9*fp_paste)
            }else if(result_type=="recall"){
              result_uni=uni_tpvalue
              result_inter=inter_tpvalue
              result_mean=mean_tpvalue
              result_paste=tp_paste
            }else if(result_type=="FPR"){
              result_uni=uni_fpvalue
              result_inter=inter_fpvalue
              result_mean=mean_fpvalue
              result_paste=fp_paste
            }
            
            results_list[[row_index]] <- data.frame(method = paste0("GASTON", "-PASTE"), set = result_type, value = result_paste, inf = inf, inte_situ = intevalue, pattern = "linear")
            results_list[[row_index + 1]] <- data.frame(method = paste0("GASTON", "-AVE"), set = result_type, value = result_mean, inf = inf, inte_situ = intevalue, pattern = "linear")
            results_list[[row_index + 2]] <- data.frame(method = paste0("GASTON", "-Union"), set = result_type, value = result_uni, inf = inf, inte_situ = intevalue, pattern = "linear")
            results_list[[row_index + 3]] <- data.frame(method = paste0("GASTON", "-Inter"), set = result_type, value = result_inter, inf = inf, inte_situ = intevalue, pattern = "linear")
            
            row_index <- row_index + 4
          }
        
      }
    }
