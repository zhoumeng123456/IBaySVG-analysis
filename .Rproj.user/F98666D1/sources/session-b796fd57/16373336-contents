time_read <- function(result,m){
  #m代表方法顺序
  if(m <=6){
    time_table= matrix(NA,nrow = 12,ncol = 3)
    for(i in c(1:3)){
      for( j in c(1:12)){
        time_table[j,i]=result[[m]][[i]][[j]][[4]]
      }
    }
  }else if(m==7){
    time_table= matrix(NA,nrow = 4,ncol = 3)
    for(i in c(1:3)){
      for( j in c(1:4)){
        time_table[j,i]=result[[m]][[i]][[j]][[4]]
      }
    }
  }else{
    time_table=matrix(NA,nrow = 4,ncol = 3)
    for(i in c(1:3)){
      for( j in c(1:4)){
        time_table[j,i]=result[[i]][[j]][[6]]
      }
    }
  }
  return(time_table)
}

