supple_simu_read_uni_inte <- function(seeddomain=c(1,2,3), name1="polynomial4",name2="polynomial4polynomial4",alpha=0.05/2,intevalue="scenario 1",name3="/dif_result_seed") {
  results_list <- list()  # 存储结果的列表
  row_index <- 1  # 记录当前的行数
  for (seed1 in seeddomain) {
    load(paste0("/Volumes/Elements/",name1,"/paste_result_seed",seed1,name2,".RData"))
    result1=total_list
    load(paste0("/Volumes/Elements/",name1,name3,seed1,name2,".RData"))
    rowname <- c("Proposed", "spVC", "SPARKX", "HEARTSVG", "SPARK", "nnSVG", "DESpace")
    result=total_list
    infvalue="inf5"
    
    spa="linear"
    print(paste0("seed",seed1))
      for(m in c(1:7)){
        if(m %in% c(2:6)){
          zero_one_table <- matrix(NA, nrow = 4, ncol = 5000)
          for (k in 1:4) {
            ttt=unname(result[[m]][[k]][[1]])
            if(length(ttt)==5000){
              zero_one_table[k, ] <- ttt
            }else{
              zero_one_table[k, ] <- c(ttt,rep(0,(5000-length(ttt))))
            }
          }
          selected_rows=c(1:4)
          
          result_mean_temp=apply(zero_one_table,2,sum)
          mean_tpvalue=mean(result_mean_temp[1:500], na.rm = TRUE)/4
          mean_fpvalue=mean(result_mean_temp[501:5000], na.rm = TRUE)/4
          mean_tfpvalue=c(mean_tpvalue,mean_fpvalue)

      
          result_uni <- apply(zero_one_table, 2, max)
          result_inter <- apply(zero_one_table, 2, min)
         
          tp_paste=result1[[m]][[1]][[6]][[1]]
          fp_paste=result1[[m]][[1]][[6]][[2]]
          # tp_paste <- result[[mdomain[m]]][[i]][[j]][[3]][1]
          # fp_paste <- result[[mdomain[m]]][[i]][[j]][[3]][2]
          uni_tpvalue <- mean(result_uni[1:500], na.rm = TRUE)
          uni_fpvalue <- mean(result_uni[501:5000], na.rm = TRUE)
          inter_tpvalue <- mean(result_inter[1:500], na.rm = TRUE)
          inter_fpvalue <- mean(result_inter[501:5000], na.rm = TRUE)
          
          for(result_type in c("F1","precision","recall","FPR")){
            if(result_type=="F1"){
              result_uni <- 2 * uni_tpvalue / (1 + 9 * uni_fpvalue + uni_tpvalue)
              result_inter <- 2 * inter_tpvalue / (1 + 9 * inter_fpvalue + inter_tpvalue)
              result_mean <- 2 * mean_tfpvalue[1] / (1 + 9 * mean_tfpvalue[2] + mean_tfpvalue[1])
              result_paste <- 2 * tp_paste / (1 + 9 * fp_paste + tp_paste)
            }else if(result_type=="precision"){
              result_uni=uni_tpvalue/(uni_tpvalue+9*uni_fpvalue)
              result_inter=inter_tpvalue/(inter_tpvalue+9*inter_fpvalue)
              result_mean=mean_tfpvalue[1]/(mean_tfpvalue[1]+9*mean_tfpvalue[2])
              result_paste=tp_paste/(tp_paste+9*fp_paste)
            }else if(result_type=="recall"){
              result_uni=uni_tpvalue
              result_inter=inter_tpvalue
              result_mean=mean_tfpvalue[1]
              result_paste=tp_paste
            }else if(result_type=="FPR"){
              result_uni=uni_fpvalue
              result_inter=inter_fpvalue
              result_mean=mean_tfpvalue[2]
              result_paste=fp_paste
            }
            
            results_list[[row_index]] <- data.frame(method = paste0(rowname[m], "-PASTE"), set = result_type, value = result_paste, inf = infvalue, inte_situ = intevalue, pattern = spa)
            results_list[[row_index + 1]] <- data.frame(method = paste0(rowname[m], "-AVE"), set = result_type, value = result_mean, inf = infvalue, inte_situ = intevalue, pattern = spa)
            results_list[[row_index + 2]] <- data.frame(method = paste0(rowname[m], "-Union"), set = result_type, value = result_uni, inf = infvalue, inte_situ = intevalue, pattern = spa)
            results_list[[row_index + 3]] <- data.frame(method = paste0(rowname[m], "-Inter"), set = result_type, value = result_inter, inf = infvalue, inte_situ = intevalue, pattern = spa)
            
            row_index <- row_index + 4
        }
      
      }else if(m==1){
        total_result <- result[[m]][[1]][[2]]
        thrs <- BayFDR(total_result, alpha / length(total_result))
        total_result[total_result > thrs] <- 1
        total_result[total_result <= thrs] <- 0

        tp <- mean(total_result[1:500], na.rm = TRUE)
        fp <- mean(total_result[501:5000], na.rm = TRUE)
        for(result_type in c("F1","precision","recall","FPR")){
          if (result_type == "F1") {
            result_proposed <- 2 * tp / (1 + 9 * fp + tp)
          } else if (result_type == "precision") {
            result_proposed <- tp / (tp + 9 * fp)
          } else if (result_type == "recall") {
            result_proposed <- tp
          }else if(result_type == "FPR"){
            result_proposed <- fp
          }
        
        results_list[[row_index]] <- data.frame(method = rowname[m], set = result_type, value = result_proposed, inf = infvalue, inte_situ = intevalue, pattern = spa)
        row_index <- row_index + 1
        }
    }else if(m==7){
            
            tp <- mean(result[[m]][[1]][[1]][1:500],na.rm = TRUE)
            fp <- mean(result[[m]][[1]][[1]][501:5000],na.rm = TRUE)

            for(result_type in c("F1","precision","recall","FPR")){
              if(result_type=="F1"){
                result_despace <- 2 * tp / (1 + 9 * fp + tp)
              }else if(result_type=="precision"){
                result_despace=tp/(tp+9*fp)
              }else if(result_type=="recall"){
                result_despace=tp
              }else if(result_type=="FPR"){
                result_despace=fp
              }
              
              results_list[[row_index]] <- data.frame(method = rowname[m], set = result_type, value = result_despace, inf = infvalue, inte_situ = intevalue, pattern = spa)
              row_index <- row_index + 1
            }
          }
        
        }
      }
  results_df <- do.call(rbind, results_list)
  return(results_df)
}
supple_simu_read_uni_inte <- function(seeddomain=c(1,2,3), name1="polynomial4",name2="polynomial4polynomial4",alpha=0.05/2,intevalue="scenario 1",name3="/dif_result_seed") {
  results_list <- list()  # 存储结果的列表
  row_index <- 1  # 记录当前的行数
  for (seed1 in seeddomain) {
    load(paste0("/Volumes/Elements/",name1,"/paste_result_seed",seed1,name2,".RData"))
    result1=total_list
    load(paste0("/Volumes/Elements/",name1,name3,seed1,name2,".RData"))
    rowname <- c("Proposed", "spVC", "SPARKX", "HEARTSVG", "SPARK", "nnSVG", "DESpace")
    result=total_list
    infvalue="inf5"
    
    spa="linear"
    print(paste0("seed",seed1))
    for(m in c(1:7)){
      if(m %in% c(2:6)){
        zero_one_gene=list()
        target_order=paste0("gene",1:5000)
        for (k in 1:4) {
          ttt=result[[m]][[k]][[2]]
          zero_one_gene[[k]]=ttt
        }
        
        
        zero_one_table1 <- matrix(NA, nrow = 4, ncol = 5000)
        for (k in 1:4) {
          ttt=unname(result[[m]][[k]][[4]])
          l=length(ttt)
          zero_one_table1[k, ] <-c(ttt,rep(1,(5000-l)))
        }
        
        p_selected=zero_one_table1
        p_selected[is.na(zero_one_table1)] <- 1
        eps <- 1e-10
        p_selected[p_selected <= eps] <- eps
        p_selected[p_selected >= 1 - eps] <- 1 - eps


        p_combined <- apply(p_selected, 2, ACAT)
        result_combined=ifelse(p_combined <= 0.05, 1, 0)
        combined_tpvalue <- mean(result_combined[1:500], na.rm = TRUE)
        combined_fpvalue <- mean(result_combined[501:5000], na.rm = TRUE)

        p_combined1 <- apply(p_selected, 2, function(p) {
          unname(p.hmp(p, L = 4))
        })
        result_combined1=ifelse(p_combined1 <= 0.05, 1, 0)
        combined1_tpvalue <- mean(result_combined1[1:500], na.rm = TRUE)
        combined1_fpvalue <- mean(result_combined1[501:5000], na.rm = TRUE)
        
        
        mean_tfpvalue <- rowMeans(sapply(c(1:4), function(k) result[[m]][[k]][[6]]))
        uni_gene_set=Reduce(union,zero_one_gene)
        inter_gene_set=Reduce(intersect,zero_one_gene)
        index1=match(uni_gene_set,target_order)
        
        uni_tpvalue <- sum(index1 <= 500, na.rm = TRUE)/500
        uni_fpvalue <- sum(index1 > 500, na.rm = TRUE)/4500
        
        index2=match(inter_gene_set,target_order)
        inter_tpvalue <- sum(index2 <= 500, na.rm = TRUE)/500
        inter_fpvalue <- sum(index2 > 500, na.rm = TRUE)/4500
        
        tp_paste=result1[[m]][[1]][[6]][[1]]
        fp_paste=result1[[m]][[1]][[6]][[2]]
