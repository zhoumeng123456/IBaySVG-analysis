BayFDR <- function(PPI, alpha){
  PPI_sorted = sort(PPI,decreasing = TRUE)
  k = 1
  fdr = 0
  while(fdr < alpha){
    fdr = mean(1 - PPI_sorted[1:k])
    k = k+1
    if(k > length(PPI_sorted)){
      k = length(PPI_sorted);
      break;
    }
  }
  return.value = PPI_sorted[k]
  return.value = ifelse(is.na(return.value), 0, return.value)
  return(return.value)
}

simu_supple_data<-function(seeddomain=c(1:50),name1="example_name1",name2="example_name2",name3="example_name3",roundnum=3,base="/dif_result_seed"){
  # 初始化一个空的矩阵，用来保存每个方法的均值和方差
  result_matrix <- matrix(0, nrow = 7, ncol = 6)  # 假设有 7 个方法
  # 设置行名称
  rowname <- c("Proposed", "spV", "SPARKX", "HEARTSVG", "SPARK", "nnSVG", "DESpace")
  rownames(result_matrix) <- rowname
  # 遍历 seed1 从 1 到 50
  for (seed1 in seeddomain) {
    # 加载对应的结果文件，逐个读取
    file_path <- paste0("/Volumes/Elements/", name1, base, seed1, name2, name3, ".RData")
    load(file_path)  # 假设加载的 result_list 是需要处理的数据
    len=length(seeddomain)
    # 遍历不同方法
    for (i in 1:7) {
      if (i == 7) {
        # 对于 i = 1 和 i = 7，直接处理每个 seed 的结果
        a <- total_list[[i]][[1]][[6]][1]  # 第一元素
        b <- total_list[[i]][[1]][[6]][2]  # 第二元素
        result_matrix[i, 1] <- result_matrix[i, 1] + a  # 第一元素的均值累计
        result_matrix[i, 2] <- result_matrix[i, 2] + a^2  # 第一元素的平方和
        result_matrix[i, 3] <- result_matrix[i, 3] + a / (a + 9 * b)  # 第一公式均值累计
        result_matrix[i, 4] <- result_matrix[i, 4] + (a / (a + 9 * b))^2  # 第一公式平方和
        result_matrix[i, 5] <- result_matrix[i, 5] + 2 * a / (1 + 9 * b + a)  # 第二公式均值累计
        result_matrix[i, 6] <- result_matrix[i, 6] + (2 * a / (1 + 9 * b + a))^2  # 第二公式平方和
      }else if(i==1){
        total_result=total_list[[i]][[1]][[1]]
        total_result <- apply(total_result, 1, max)
        thrs <- BayFDR(total_result, 0.05/2/length(total_result))
        total_result[total_result > thrs] <- 1
        total_result[total_result <= thrs] <- 0
        a=mean(total_result[1:500],na.rm=TRUE)
        b=mean(total_result[501:5000],na.rm=TRUE)
        result_matrix[i, 1] <- result_matrix[i, 1] + a  # 第一元素的均值累计
        result_matrix[i, 2] <- result_matrix[i, 2] + a^2  # 第一元素的平方和
        result_matrix[i, 3] <- result_matrix[i, 3] + a / (a + 9 * b)  # 第一公式均值累计
        result_matrix[i, 4] <- result_matrix[i, 4] + (a / (a + 9 * b))^2  # 第一公式平方和
        result_matrix[i, 5] <- result_matrix[i, 5] + 2 * a / (1 + 9 * b + a)  # 第二公式均值累计
        result_matrix[i, 6] <- result_matrix[i, 6] + (2 * a / (1 + 9 * b + a))^2  # 第二公式平方和
      }else {
        # 对于 i = 2 到 6，计算 total_list[[i]][[j]] 中每个 j 的均值
        mean_a <- mean(sapply(1:4, function(j) total_list[[i]][[j]][[6]][1]))  # 第一元素的均值
        mean_b <- mean(sapply(1:4, function(j) total_list[[i]][[j]][[6]][2]))  # 第二元素的均值
        result_matrix[i, 1] <- result_matrix[i, 1] + mean_a  # 第一元素的均值累计
        result_matrix[i, 2] <- result_matrix[i, 2] + mean_a^2  # 第一元素的平方和
        result_matrix[i, 3] <- result_matrix[i, 3] + mean_a / (mean_a + 9 * mean_b)  # 第一公式均值累计
        result_matrix[i, 4] <- result_matrix[i, 4] + (mean_a / (mean_a + 9 * mean_b))^2  # 第一公式平方和
        result_matrix[i, 5] <- result_matrix[i, 5] + 2 * mean_a / (1 + 9 * mean_b + mean_a)  # 第二公式均值累计
        result_matrix[i, 6] <- result_matrix[i, 6] + (2 * mean_a / (1 + 9 * mean_b + mean_a))^2  # 第二公式平方和
      }
    }
  }
  
  # 计算每个方法的均值和方差（已经累计所有 seed 的结果）
  result_matrix[, 1] <- result_matrix[, 1] / len  # 第一元素的均值
  result_matrix[, 3] <- result_matrix[, 3] / len  # 第一公式的均值
  result_matrix[, 5] <- result_matrix[, 5] / len  # 第二公式的均值
  
  # 计算方差
  result_matrix[, 2] <- result_matrix[, 2] / len - result_matrix[, 1]^2  # 第一元素的方差
  result_matrix[, 4] <- result_matrix[, 4] / len - result_matrix[, 3]^2  # 第一公式的方差
  result_matrix[, 6] <- result_matrix[, 6] / len - result_matrix[, 5]^2  # 第二公式的方差
  
  result_matrix <- round(result_matrix, roundnum)
  
  result_df <- matrix(0, nrow = 7, ncol = 3)
  rownames(result_df) <- rowname
  
  result_df[, 1] <- paste0(format(result_matrix[, 1], digits = 3, nsmall = 3), "(", format(result_matrix[, 2], digits = 3, nsmall = 3), ")")
  result_df[, 2] <- paste0(format(result_matrix[, 3], digits = 3, nsmall = 3), "(", format(result_matrix[, 4], digits = 3, nsmall = 3), ")")
  result_df[, 3] <- paste0(format(result_matrix[, 5], digits = 3, nsmall = 3), "(", format(result_matrix[, 6], digits = 3, nsmall = 3), ")")
  
  print(result_matrix)
  # 输出结果
  return(result_df)
}
