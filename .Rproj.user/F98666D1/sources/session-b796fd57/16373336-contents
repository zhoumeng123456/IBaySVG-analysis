our_read <- function(seeddomain = c(1,2,3), spa = "period", alpha = 0.05/2) {
  results_list <- list()  # 用于存储结果的列表
  row_index <- 1  # 记录当前行的索引
  
  for (seed1 in seq_along(seeddomain)) {
    print(paste0("The seed is ", seeddomain[seed1]))
    load(paste0("/Volumes/Elements/模拟结果/", spa, "/our", spa, seeddomain[seed1], ".RData"))
    
    for (i in 1:3) {
      for (j in 1:4) {
        total_result <- result_list[[i]][[j]][[2]]
        thrs <- BayFDR(total_result, alpha / length(total_result))
        total_result[total_result > thrs] <- 1
        total_result[total_result <= thrs] <- 0
        
        tp <- mean(total_result[1:500], na.rm = TRUE)
        fp <- mean(total_result[501:5000], na.rm = TRUE)
        
        infvalue <- switch(i, "inf1", "inf3", "inf5")
        intevalue <- switch(j, "scenario 1", "scenario 2", "scenario 3", "scenario 4")
        for(result_type in c("F1","precision","recall","FPR")){
        if (result_type == "F1") {
          result_proposed <- 2 * tp / (1 + 9 * fp + tp)
        } else if (result_type == "precision") {
          result_proposed <- tp / (tp + 9 * fp)
        } else if (result_type == "recall") {
          result_proposed <- tp
        }else if(result_type=="FPR"){
          result_proposed=fp
        }
        
        # 存入列表
        results_list[[row_index]] <- data.frame(
          method = "Proposed",
          set = result_type,
          value = result_proposed,
          inf = infvalue,
          inte_situ = intevalue,
          pattern = spa
        )
        row_index <- row_index + 1
        }
      }
    }
  }
  
  # 合并所有结果为数据框
  return(do.call(rbind, results_list))
}
other_read_uni_inte <- function(seeddomain=c(1,2,3), spa="period", mdomain=c(1,2,3,4,6,7),seeddomain2=c(1:50)) {
  results_list <- list()  # 存储结果的列表
  row_index <- 1  # 记录当前的行数
  for (seed1 in seq_along(seeddomain)) {
    print(seed1)
    load(paste0("/Volumes/Elements/模拟结果/", spa, "/", spa, seeddomain[seed1], ".RData"))
    for (m in seq_along(mdomain)) {
      rowname <- c("spVC", "SPARKX", "HEARTSVG", "SPARK", "nnSVG", "DESpace")
      result <- nested_list
      
      if (m %in% c(1,3,4)) {
        for (i in 1:3) {
          for (j in 1:4) {
            # 提取 tp / fp
            infvalue <- c("inf1", "inf3", "inf5")[i]
            
            # 计算 mean_tfpvalue & zero_one_table
            zero_one_table <- matrix(NA, nrow = 8, ncol = 5000)
            for (k in 5:12) {
              zero_one_table[(k-4), ] <- result[[mdomain[m]]][[i]][[k]][[2]]
            }
            
            zero_one_table1 <- matrix(NA, nrow = 8, ncol = 5000)
            for (k in 5:12) {
              zero_one_table1[(k-4), ] <- result[[mdomain[m]]][[i]][[k]][[1]]
            }
            
            
            scenario_sets <- list(
              c(1:4),  # scenario 1
              c(1,2,5,6),  # scenario 2
              c(3:6),  # scenario 3
              c(2,5,7,8)  # scenario 4
            )
            intevalue <- paste0("scenario ", j)
            selected_rows <- scenario_sets[[j]]
            
            #
            p_selected=zero_one_table1[selected_rows, ]
            p_selected[is.na(p_selected)] <- 1
            eps <- 1e-10
            p_selected[p_selected <= eps] <- eps
            p_selected[p_selected >= 1 - eps] <- 1 - eps
            
            
            p_combined <- apply(p_selected, 2, ACAT)
            result_combined=ifelse(p_combined <= 0.05, 1, 0)
            combined_tpvalue <- mean(result_combined[1:500], na.rm = TRUE)
            combined_fpvalue <- mean(result_combined[501:5000], na.rm = TRUE)
            
            p_combined1 <- apply(p_selected, 2, function(p) {
              unname(p.hmp(p, L = 4))
            })
            result_combined1=ifelse(p_combined1 <= 0.05, 1, 0)
            combined1_tpvalue <- mean(result_combined1[1:500], na.rm = TRUE)
            combined1_fpvalue <- mean(result_combined1[501:5000], na.rm = TRUE)
            

            mean_tfpvalue <- rowMeans(sapply(selected_rows, function(k) result[[mdomain[m]]][[i]][[k+4]][[3]]))
            result_uni <- apply(zero_one_table[selected_rows, ], 2, max)
            result_inter <- apply(zero_one_table[selected_rows, ], 2, min)
            
            tp_paste <- result[[mdomain[m]]][[i]][[j]][[3]][1]
            fp_paste <- result[[mdomain[m]]][[i]][[j]][[3]][2]
            uni_tpvalue <- mean(result_uni[1:500], na.rm = TRUE)
            uni_fpvalue <- mean(result_uni[501:5000], na.rm = TRUE)
            inter_tpvalue <- mean(result_inter[1:500], na.rm = TRUE)
            inter_fpvalue <- mean(result_inter[501:5000], na.rm = TRUE)
            
            for(result_type in c("F1","precision","recall","FPR")){
            if(result_type=="F1"){
              result_uni <- 2 * uni_tpvalue / (1 + 9 * uni_fpvalue + uni_tpvalue)
              result_inter <- 2 * inter_tpvalue / (1 + 9 * inter_fpvalue + inter_tpvalue)
              result_mean <- 2 * mean_tfpvalue[1] / (1 + 9 * mean_tfpvalue[2] + mean_tfpvalue[1])
              result_paste <- 2 * tp_paste / (1 + 9 * fp_paste + tp_paste)
              result_combine<- 2 * combined_tpvalue / (1 + 9 * combined_fpvalue + combined_tpvalue)
              result_combine1<- 2 * combined1_tpvalue / (1 + 9 * combined1_fpvalue + combined1_tpvalue)
            }else if(result_type=="precision"){
              result_uni=uni_tpvalue/(uni_tpvalue+9*uni_fpvalue)
              result_inter=inter_tpvalue/(inter_tpvalue+9*inter_fpvalue)
              result_mean=mean_tfpvalue[1]/(mean_tfpvalue[1]+9*mean_tfpvalue[2])
              result_paste=tp_paste/(tp_paste+9*fp_paste)
              result_combine<- combined_tpvalue / (9 * combined_fpvalue + combined_tpvalue)
              result_combine1<- combined1_tpvalue / (9 * combined1_fpvalue + combined1_tpvalue)
            }else if(result_type=="recall"){
              result_uni=uni_tpvalue
              result_inter=inter_tpvalue
              result_mean=mean_tfpvalue[1]
              result_paste=tp_paste
              result_combine=combined_tpvalue
              result_combine1=combined1_tpvalue
            }else if(result_type=="FPR"){
              result_uni=uni_fpvalue
              result_inter=inter_fpvalue
              result_mean=mean_tfpvalue[2]
              result_paste=fp_paste
              result_combine=combined_fpvalue
              result_combine1=combined1_fpvalue
            }
            
            results_list[[row_index]] <- data.frame(method = paste0(rowname[m], "-PASTE"), set = result_type, value = result_paste, inf = infvalue, inte_situ = intevalue, pattern = spa)
            results_list[[row_index + 1]] <- data.frame(method = paste0(rowname[m], "-AVE"), set = result_type, value = result_mean, inf = infvalue, inte_situ = intevalue, pattern = spa)
