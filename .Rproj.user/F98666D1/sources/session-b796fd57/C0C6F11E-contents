normal_create <- function(gene_size =100,svgene_size=0.1,inf_size=0,kernel="exp"
                          ,seed=1,cell_dist=rep(1,6),domainnum=1,tau1=1,tau2=1,num_cores=8,simu_type=1){
  ###
  ###
  set.seed(seed)
  x_coords <- rep(0:31, each = 32)
  y_coords <- rep(0:31, times = 32)
  if(domainnum==1){
    z_type <- c(rep(rep(1:2,each=16),9),rep(1,96),rep(c(rep(3,12),rep(4,20)),10),rep(3,128),rep(rep(3:4,each=16),6))#横平竖直的分成了四个区域
  }else if(domainnum==2){
    z_type <- rep(1,1024)
  }else if(domainnum==3){
    z_type <- c(rep(1,512),rep(2,512))
  }else if(domainnum==4){
    z_type <- c(rep(rep(1:2,each=16),16),rep(3,512))
  }else if(domainnum==5){
    z_type <- c(rep(c(rep(1,20),rep(2,12)),16),rep(c(rep(3,12),rep(1,8),rep(4,12)),4),rep(rep(3:4,each=16),12))
  }else if(domainnum==6){
    z_type <- c(rep(c(rep(2,12),rep(1,20)),16),rep(c(rep(2,12),rep(3,20)),6),rep(3,320))
  }else if(domainnum==7){
    #判断是否是3号的偏差影响太大
    z_type <- c(rep(c(rep(2,12),rep(1,20)),16),rep(c(rep(2,12),rep(3,20)),6),rep(5,320))
  }else if(domainnum==8){
    z_type <- c(rep(c(rep(2,12),rep(1,20)),16),rep(c(rep(2,12),rep(3,20)),6),rep(4,320))
  }else if(domainnum==9){
    z_type <- c(rep(c(rep(1,20),rep(2,12)),16),rep(c(rep(3,12),rep(1,8),rep(4,12)),8),rep(rep(3:4,each=16),8))
  }else if(domainnum==10){
    z_type <- c(rep(c(rep(1,20),rep(2,12)),16),rep(c(rep(3,4),rep(1,16),rep(4,12)),4),rep(rep(3:4,each=16),12))
  }else if(domainnum==11){
    #
    z_type <- c(rep(rep(2:3,each=16),16),rep(1,512))
  }
  
  location <- data.frame(x = x_coords, y = y_coords, z = z_type)
  
  # 标准化坐标
  location$x <- scale(location$x)
  location$y <- scale(location$y)
  
  location=as.matrix(location)
  # 计算欧式距离矩阵（优化）
  xy_mat <- location[, 1:2]
  kernel_matrix <- as.matrix(getFromNamespace("dist", "stats")(xy_mat))
  
  base_corr=tau2*diag(rep(1,1024))
  epsilon <- 1e-10
  #生成对应的协方差矩阵
  if(kernel=="exp"){
    kernel_matrix=exp(-kernel_matrix^2/2)*tau1+base_corr+ epsilon
  }else if(kernel == "cos"){
    kernel_matrix=cos(2*pi*kernel_matrix)*tau1+base_corr+ epsilon
  }else if(kernel == "linear"){
    kernel_matrix=kernel_matrix*tau1+base_corr+ epsilon
  }
  
  kernel_matrix=round(kernel_matrix,3)
  kern_coord<-cbind(location[,1],location[,2])
  
  npoints <- nrow(location)
  rownames(location) = paste('spot', 1:npoints, sep = '')
  
  expres_marx = as.data.frame(matrix(NA, nrow = npoints, ncol = gene_size))
  rownames(expres_marx) = paste('spot', 1:npoints, sep = '')
  colnames(expres_marx) = paste('gene', 1:gene_size, sep = '')
  
  sv_points=svgene_size*gene_size
  sv_gene <- c(1:sv_points)##设定前多少个为SV基因
  no_sv_gene <- setdiff(1:gene_size, sv_gene)##设定其余的基因为非SV基因
  
  cell_matrix <- matrix(NA,nrow = npoints,ncol = 6)
  rownames(cell_matrix)=paste('spot', 1:npoints, sep = '')
  
  alpha_list <- list(
    c(1,1,1,1,1,1),
    c(1,3,5,7,9,11),
    c(14,12,10,8,6,4),
    c(1,4,4,4,4,1),
    c(18,16,14,12,10,8)
  )
  
  cell_matrix <- t(sapply(z_type, function(z) rdirichlet(1, alpha_list[[z]])))
  
  cell_mark <- rnorm(6,mean=0,sd=1)
  
  nor_mean <- rowSums(cell_matrix * cell_mark)
  
  # kernel_matrix=make_positive_definite(kernel_matrix)
  kernel_matrix <- as.matrix(nearPD(kernel_matrix, corr = FALSE)$mat)
  
  
  covariances_sv <- kernel_matrix
  covariances_no_sv <- base_corr
  
  # Apply the corresponding covariance matrix to each gene group in parallel
  cl <- makeCluster(num_cores)
  clusterExport(cl, c("nor_mean", "mvrnorm", "covariances_sv", "covariances_no_sv"), envir = environment())
  
  # Parallel computation for sv_gene
  results_sv <- parLapply(cl, seq_along(sv_gene), function(i) {
    Sigma <- covariances_sv
    mvrnorm(n = 1, mu = nor_mean, Sigma = Sigma)
  })
  
  # Parallel computation for no_sv_gene
  results_no_sv <- parLapply(cl, seq_along(no_sv_gene), function(i) {
    Sigma <- covariances_no_sv
    mvrnorm(n = 1, mu = nor_mean, Sigma = Sigma)
  })
  
  stopCluster(cl)
  
  # Combine the results
  expres_marx[, sv_gene] <- do.call(cbind, results_sv)
  expres_marx[, no_sv_gene] <- do.call(cbind, results_no_sv)
  
  
  if(simu_type==1){
    expres_marx[expres_marx<0]=0
  }else{
    expres_marx=exp(expres_marx)
  }
  
  expres_marx=round(expres_marx)
  ##添加零膨胀率。
  expres_marx <- as.matrix(expres_marx)
  # total.size <- npoints*gene_size
  # zero_size<-floor(npoints*gene_size*inf_size)
  # zeroin<-sample(c(1:total.size),zero_size)
  # expres_marx[zeroin]<-0
  location <- as.matrix(location[,1:2])
  
  return(list(expres_marx,location,cell_matrix))
}



make_positive_definite <- function(kernel_matrix) {
  epsilon <- 1e-8  # 小的增量
  while (TRUE) {
    # 检查协方差矩阵是否正定
    eigen_values <- eigen(kernel_matrix)$values
    if (all(eigen_values > 0)) {
      # 如果是正定的，返回该矩阵
      return(kernel_matrix)
    } else {
      # 否则，增加对角线的值
      kernel_matrix <- kernel_matrix + diag(epsilon, nrow(kernel_matrix))
    }
  }
}
