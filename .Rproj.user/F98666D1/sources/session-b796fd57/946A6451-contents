library(PRECAST)
produce_cluster<-function(matrix,position,k_num=4){
  seurat_obj <- CreateSeuratObject(counts = matrix, assay = "RNA")
  
  colnames(position) <- c("row", "col") 
  rownames(position) <- colnames(matrix)  
  
  # 3. 添加坐标到 meta.data
  seurat_obj@meta.data$row <- position[rownames(seurat_obj@meta.data), "row"]
  seurat_obj@meta.data$col <- position[rownames(seurat_obj@meta.data), "col"]
  seurat_obj
  
  preobj <- CreatePRECASTObject(seuList = list(seurat_obj), selectGenesMethod = "HVGs", gene.number = 5000)
  
  PRECASTObj <- AddAdjList(preobj, platform = "ST")
  PRECASTObj <- AddParSetting(PRECASTObj, Sigma_equal = FALSE, coreNum = 8, maxIter = 30, verbose = TRUE)
  PRECASTObj <- PRECAST(PRECASTObj, K = k_num)
  resList <- PRECASTObj@resList
  
  cluster <-as.character(unlist(PRECASTObj@resList[[1]]$cluster))
  return(cluster)
}

