        cold=cbind(position3,layer_barco3,rep(3,length(rownames(position3))))
        colnames(cold)[1:2]=c("array_row","array_col")
        colnames(cold)[4]="sample_id"
        colnames(cold)[3]="z_type"
        spe3<- SpatialExperiment(
          assay = list(counts = t(matrix3)),
          colData = cold,
          rowData = paste("gene",1:length(colnames(matrix3)))
        )
        rownames(spe3)=rowData(spe3)$X
        
        cold=cbind(position4,layer_barco4,rep(4,length(rownames(position4))))
        colnames(cold)[1:2]=c("array_row","array_col")
        colnames(cold)[4]="sample_id"
        colnames(cold)[3]="z_type"
        spe4<- SpatialExperiment(
          assay = list(counts = t(matrix4)),
          colData = cold,
          rowData = paste("gene",1:length(colnames(matrix4)))
        )
        rownames(spe4)=rowData(spe4)$X
        
        spe.combined =cbind(spe1,spe2,spe3,spe4,deparse.level = 1)
        multi_results <- DESpace_test(spe=spe.combined,spatial_cluster="z_type",sample_col ="sample_id",replicates = TRUE)
        result= multi_results$gene_results
        id <- result$gene_id
        padj <- result$PValue
        
        p_value=padj
        padj[padj<=0.05] <- 0
        padj[padj>0.05] <- 1
        padj=1-padj
        result_value=padj
        despacegenename=id[padj==1]
        
        tp=mean(result_value[1:500],na.rm=TRUE)
        fp=mean(result_value[501:5000],na.rm=TRUE)
        tfp_value=c(tp,fp)
        print(paste0("tp=",tp,"fp=",fp))
        
        end=Sys.time()
        time_value=as.numeric((end-begin), units = "mins")
        result=list(result_value,time_value,tfp_value,p_value,multi_results,tfp_value)
        nested_list[[7]][[num2]][[de1]]=result
      }
      }
      
    }
    
    save(nested_list,file=paste0(curdir,spa,seed1,"_no_cov_paste.RData"))
  }
}


