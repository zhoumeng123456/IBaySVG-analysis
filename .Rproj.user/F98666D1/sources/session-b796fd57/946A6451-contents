dataanalysis_other=function(matrixlist,positionlist,num_cores=24){
  result_sparx=replicate(8, list(), simplify = FALSE)
  for(dataindex in c(1:8)){
    exp_mat=matrixlist[[dataindex]]
    print(dim(exp_mat))
    position=positionlist[[dataindex]]
    print(dim(position))
    
    exp_mat <- t(exp_mat)
    
    genename=colnames(exp_mat)
    
    barcode=rownames(exp_mat)
    
    loc=position
    rownames(loc)=paste0("spot",1:length(rownames(loc)))
    rownames(exp_mat) <- paste0("spot",1:length(rownames(exp_mat)))
    colnames(exp_mat) <- paste0("gene",1:length(colnames(exp_mat)))
    
    head(loc)
    begin=Sys.time()
    sparkX <- sparkx(exp_mat,loc,X_in = NULL,numCores=num_cores,option="mixture",verbose = FALSE)
    sparkX$res_mtest <- as.matrix(sparkX$res_mtest)
    result <- sparkX$res_mtest[,2]##p值
    p_value=result##获得p值
    result[result<=0.05]=0
    result[result>0.05]=1
    result <- 1-result
    result_value=result##获得选择后的1/0
    tp=mean(result_value[1:500],na.rm=TRUE)
    fp=mean(result_value[501:5000],na.rm=TRUE)
    print(paste0("tp: ",tp,"fp: ",fp))
    tfp=c(tp,fp)
    target_order <- paste0("gene",1:length(genename))
    sparkx_genename=rownames(sparkX$res_mtest)[result==1]
    index <- match(sparkx_genename,target_order)
    sparkxsvgene=genename[index]
    
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,sparkxsvgene,time_value,p_value,tfp,sparkX$res_mtest)
    result_sparx[[dataindex]]=result
  }
  return(result_sparx)
}

