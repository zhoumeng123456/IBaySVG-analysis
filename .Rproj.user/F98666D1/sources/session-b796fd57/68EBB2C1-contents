#7.StarTrail: Available on https://github.com/JiawenChenn/StarTrail
library(StarTrail)

#(1)produce the boundary of the covariates in R environment
for(datanum in c(1:4)){
  count=data_example[[datanum]][[3]]#here use the covariate matrix to generate the boundary
  genename=colnames(count)
  spotname=rownames(count)
  coords=data_example[[datanum]][[2]]
  coords = coords-min(coords)
  coords = coords/max(coords)
  gene_exp=matrix(NA,nrow = length(spotname),ncol = (length(genename)+4))
  gene_exp[,1]=spotname
  gene_exp[,c(2:3)]=coords[,c(1:2)]
  gene_exp[,4]=data_example[[datanum]][[5]]
  gene_exp[,c(5:(length(genename)+4))]=count[,c(1:length(genename))]
  colnames(gene_exp)=c("id","x","y","layer",genename)
  model_list=list()
  gradient_list=list()
  thread = 12
  for(cell_name in c(1:dim(data_example[[datanum]][[3]])[2])){
    y = gene_exp[,genename[cell_name]]
    m.r = fit_NNGP(coords,y,10,thread) 
    model_list[[cell_name]]=m.r
    
    coord_dist = cdist_r(coords,coords)
    coord_dist_temp  = coord_dist
    diag(coord_dist_temp)=10000
    min_sep = min(coord_dist_temp)
    
    coord_mesh_x = seq(min(coords[,1]),max(coords[,1]),length.out=100)
    coord_mesh_y = seq(min(coords[,2]),max(coords[,2]),length.out=100)
    coord_mesh = expand.grid(coord_mesh_x,coord_mesh_y) %>% as.matrix()
    
    index_keep = coord_filter(coord_mesh, coords, close_dis = min_sep, distance_to_boundary = min_sep*2)
    coord_mesh=coord_mesh[index_keep,]
    
    gradient_mesh = finite_difference(coord_mesh,min_sep*0.8,m.r,threads=thread,prefix = 'mesh',path=path)
    gradient_mesh = cbind(coord_mesh,gradient_mesh)
    colnames(gradient_mesh)[1:2] = c('s1','s2')
    
    gradient_list[[cell_name]]=gradient_mesh
    fwrite(gradient_mesh,paste0("example_",datanum,"_gradient_gene",cell_name,".txt"),col.names=TRUE,sep="\t")
  }
  save(gradient_list,file=paste0("example_",datanum,"_gradient.RData"))
  save(model_list,file=paste0("example_",datanum,"_model.RData"))
}

