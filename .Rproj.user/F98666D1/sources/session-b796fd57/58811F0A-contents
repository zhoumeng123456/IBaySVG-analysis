all_svg = list(set(cont_svg + discont_svg))


all_svg_sorted = sorted(all_svg)
with open(f"/gemini/code/GASTON_SVG_list{dataname}.txt", "w", encoding="utf-8") as f:
  for gene in all_svg_sorted:
    f.write(gene + "\n")
