generate_new <- function(mu, var, n = 40){
  
  # 如果方差非常小，直接返回常数
  if(var <= 1e-10){
    return(rep(mu, n))
  }
  
  # 正态抽样
  out <- rnorm(n, mean = mu, sd = sqrt(var))
  
  # 截断到 [0,1]
  out[out > 1] <- 1
  out[out < 0] <- 0
  
  return(out)
}


