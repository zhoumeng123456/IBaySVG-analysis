dataanalysis_other=function(matrixlist,positionlist,calphalist,boundlist,layer_barcode,dataname="nofilter_1208",ifde=TRUE,num_cores=24,datanum=4){
  result_total=replicate(6, replicate(datanum, list(), simplify = FALSE), simplify = FALSE)
