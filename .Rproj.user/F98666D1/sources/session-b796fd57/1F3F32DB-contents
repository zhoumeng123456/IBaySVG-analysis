    colnames(cold)[3]="z_type"
    spe4<- SpatialExperiment(
      assay = list(counts = matrixlist[[4]]),
      colData = cold,
      rowData = paste("gene",1:length(rownames(matrixlist[[4]])))
    )
    rownames(spe4)=rowData(spe4)$X
    
    
    #####筛选：
    for(i in seq_len(4)){
      spe_i <- eval(parse(text = paste0("spe", i)))
      spe_i <- scuttle::addPerCellQC(spe_i,)
      spe_i <- spe_i[, !(colData(spe_i)$sum < 10 |            
                           colData(spe_i)$detected < 10)]  # library size/number of expressed genes
      # Select QC threshold for lowly expressed genes: at least 20 non-zero spots:
      qc_low_gene <- rowSums(assays(spe_i)$counts > 0) >= 20
      # Remove lowly abundant genes
      spe_i <- spe_i[qc_low_gene,]
      assign(paste0("spe", i), spe_i)
      message("Dimension of spe", i, ": ", dim(spe_i)[1], ", ", dim(spe_i)[2])
    }
    
    # find vector of common genes across all samples:
    a <- rownames(counts(spe1)); 
    b <- rownames(counts(spe2)); 
    c <- rownames(counts(spe3));
    d <- rownames(counts(spe4))
    CommonGene <- Reduce(intersect, list(a,b,c,d))
    spe1 <- spe1[CommonGene,]
    spe2 <- spe2[CommonGene,]
    spe3 <- spe3[CommonGene,]
    spe4 <- spe4[CommonGene,]
    
    spe.combined =cbind(spe1,spe2,spe3,deparse.level = 1)
    multi_results <- DESpace_test(spe=spe.combined,spatial_cluster="z_type",sample_col = "sample_id",replicates = TRUE)
    result= multi_results$gene_results
    id <- result$gene_id
    padj <- result$PValue
