expression_handle=function(dir="118D"){
  file_path=paste0("/Users/zhoumeng/Desktop/TNBC/",dir,"matrix.h5")
  data    <- as.numeric(h5read(file_path, "/matrix/data"))
  indices <- as.integer(h5read(file_path, "/matrix/indices"))
  indptr  <- as.integer(h5read(file_path, "/matrix/indptr"))
  shape   <- as.integer(h5read(file_path, "/matrix/shape"))  
  expression <- new("dgCMatrix",
                    Dim = shape,
                    x = data,
                    i = indices,
                    p = indptr)
  rownames(expression) <- h5read(file_path, "/matrix/features/name")
  colnames(expression) <- h5read(file_path, "/matrix/barcodes")
  return(expression)
}

