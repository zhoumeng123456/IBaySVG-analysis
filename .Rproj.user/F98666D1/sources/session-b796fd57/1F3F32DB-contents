pdac_handle <-function(mat){
  spotname=colnames(mat)
  x_coord <- as.integer(sub("X(\\d+)x(\\d+)", "\\1", spotname))
  y_coord <- as.integer(sub("X(\\d+)x(\\d+)", "\\2", spotname))
