    exp_mat=matrixlist[[dataindex]]
    print(dim(exp_mat))
    position=positionlist[[dataindex]]
    print(dim(position))
    calpha=calphalist[[dataindex]]
    print(dim(calpha))
    bound=boundlist[[dataindex]]
    
    exp_mat <- t(exp_mat)
    genename=colnames(exp_mat)
    barcode=rownames(exp_mat)
    loc=position
    rownames(loc)=paste0("spot",1:length(rownames(loc)))
    rownames(exp_mat) <- paste0("spot",1:length(rownames(exp_mat)))
    colnames(exp_mat) <- paste0("gene",1:length(colnames(exp_mat)))
    calpha_mat <- calpha
    rownames(calpha_mat) <- paste0("spot",1:length(rownames(exp_mat)))
    begin=Sys.time()
    tr_mat=bound
    Tr.cell <- TriMesh(tr_mat, n = 2) 
    V <- as.matrix(Tr.cell$V)
    Tr <- as.matrix(Tr.cell$Tr)
    simu.results <- test.spVC(Y = t(exp_mat), X = calpha_mat, S = loc, V = V, Tr = Tr,
                              para.cores = num_cores, filter.min.nonzero = 10)
    
    result1 <- rep(1,length(simu.results$results.constant))
    result <- rep(NA,length(genename))
    for( i in c(1:length(simu.results$results.constant))){
      result1[i]=unname(simu.results$results.constant[[i]][[1]]["gamma_0"])
    }
    target_order <- paste0("gene",1:length(genename))
    p_value=result1##获得p值
    result1[result1<=0.05] <- 0
    result1[result1>0.05] <- 1
    result1=1-result1
    result_value=result1##获得选择后的1/0
    spv_genename=names(simu.results$results.constant)[result1==1]
    index <- match(spv_genename,target_order)
    spvsvgene=genename[index]
    #包装结果
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,spvsvgene,time_value,p_value,simu.results$results.constant)
    result_total[[1]][[dataindex]]=result
    print(length(result_total[[1]][[dataindex]]))
    
    ##heartsvg
    ##heartsvg
    begin=Sys.time()
    mat <- cbind(loc,exp_mat)
    colnames(mat)[1:2] = c("row","col")
    result <- heartsvg(mat)
    hea_result=result
    aaa <- result$gene
    bbb <- result$p_adj
    
    p_value=bbb
    bbb[bbb<=0.05]=0
    bbb[bbb>0.05]=1
    bbb <- 1-bbb
    result_value=bbb
    heartsvg_genename=aaa[bbb==1]
    target_order <- paste0("gene",1:length(genename))
    index <- match(heartsvg_genename,target_order)
    heartsvgene=genename[index]
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,heartsvgene,time_value,p_value,hea_result$gene)
    result_total[[2]][[dataindex]]=result
    
    ###sparkx
    ###sparkx
    begin=Sys.time()
    sparkX <- sparkx(t(exp_mat),loc,calpha_mat[,c(1:5)],numCores=num_cores,option="mixture",verbose = FALSE)
    sparkX$res_mtest <- as.matrix(sparkX$res_mtest)
    result <- sparkX$res_mtest[,2]##p值
    p_value=result##获得p值
    result[result<=0.05]=0
    result[result>0.05]=1
    result <- 1-result
    result_value=result##获得选择后的1/0
    target_order <- paste0("gene",1:length(genename))
    sparkx_genename=rownames(sparkX$res_mtest)[result==1]
    index <- match(sparkx_genename,target_order)
    sparkxsvgene=genename[index]
    
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,sparkxsvgene,time_value,p_value,sparkX$res_mtest)
    result_total[[3]][[dataindex]]=result
    
    
    ##spark
    ##spark
    begin=Sys.time()
    spark <- CreateSPARKObject(counts=t(exp_mat),
                               location=as.data.frame(loc),
                               percentage = 0.1,
                               min_total_counts = 10)##构建spark对象
    spark@lib_size <- apply(spark@counts, 2, sum)
    spark <- spark.vc(spark,
                      covariates = NULL,
                      lib_size = spark@lib_size,
                      num_core = num_cores,
                      verbose = F)
    spark <- spark.test(spark,
                        check_positive = T,
                        verbose = F)##计算p值
    result <- spark@res_mtest[,"adjusted_pvalue"]
    spark_genename=rownames(spark@res_mtest)
    p_value=result
    result[result<=0.05] <- 0
    result[result>0.05] <- 1
    result=1-result
    result_value=result
    spark_genename=spark_genename[result==1]##符合结果的gene列表
    target_order <- paste0("gene",1:length(genename))
    index <- match(spark_genename,target_order)
    sparksvgene=genename[index]
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,sparksvgene,time_value,p_value,spark@res_mtest)
    result_total[[4]][[dataindex]]=result
    
    
    ##nnsvg
    ##nnsvg###删去了90%
    begin=Sys.time()
    spe<- SpatialExperiment(
      assay = list(counts = t(exp_mat)),
      colData = loc, 
      spatialCoordsNames = c("row", "col")
    )
    rowData(spe)$gene_name <- paste0("gene",1:length(colnames(exp_mat)))
    spe <- filter_genes(spe)
    spe <- computeLibraryFactors(spe)
    spe <- logNormCounts(spe)
    spe <- nnSVG(spe,n_threads = num_cores,X=calpha_mat)
    spv_genename=rowData(spe)$gene_name
    result=rowData(spe)$padj
    p_value=result
    result[result<=0.05] <- 0
    result[result>0.05] <- 1
    result=1-result
    result_value=result
