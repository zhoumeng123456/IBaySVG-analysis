    result_total[[4]][[dataindex]]=result
    
    
    ##nnsvg
    ##nnsvg###删去了90%
    begin=Sys.time()
    spe<- SpatialExperiment(
      assay = list(counts = t(exp_mat)),
      colData = loc, 
      spatialCoordsNames = c("x", "y")
    )
    rowData(spe)$gene_name <- paste0("gene",1:length(colnames(exp_mat)))
    spe <- filter_genes(spe)
    spe <- computeLibraryFactors(spe)
    spe <- logNormCounts(spe)
    spe <- nnSVG(spe,n_threads = num_cores,X=calpha_mat)
    spv_genename=rowData(spe)$gene_name
    result=rowData(spe)$padj
    p_value=result
    result[result<=0.05] <- 0
    result[result>0.05] <- 1
    result=1-result
    result_value=result
    spv_genename=spv_genename[result==1]
    target_order <- paste0("gene",1:length(genename))
    index <- match(spv_genename,target_order)
    nnsvgsvgene <- genename[index]
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,nnsvgsvgene,time_value,p_value,rowData(spe))
    result_total[[5]][[dataindex]]=result
  }
  
  if(ifde){
    ##DEspace
    begin=Sys.time()
    #matrix矩阵：基因✖️点位
    
    #生成完整的spe，
    cold=cbind(positionlist[[1]],layer_barcode[[1]],rep(1,length(rownames(positionlist[[1]]))))
    colnames(cold)[1:2]=c("array_row","array_col")
    colnames(cold)[4]="sample_id"
    colnames(cold)[3]="z_type"
    spe1<- SpatialExperiment(
      assay = list(counts = matrixlist[[1]]),
      colData = cold,
      rowData = paste("gene",1:length(rownames(matrixlist[[1]])))
    )
    rownames(spe1)=rowData(spe1)$X
    
    cold=cbind(positionlist[[2]],layer_barcode[[2]],rep(2,length(rownames(positionlist[[2]]))))
    colnames(cold)[1:2]=c("array_row","array_col")
    colnames(cold)[4]="sample_id"
    colnames(cold)[3]="z_type"
    spe2<- SpatialExperiment(
      assay = list(counts = matrixlist[[2]]),
      colData = cold,
      rowData = paste("gene",1:length(rownames(matrixlist[[2]])))
    )
    rownames(spe2)=rowData(spe2)$X
    
    cold=cbind(positionlist[[3]],layer_barcode[[3]],rep(3,length(rownames(positionlist[[3]]))))
    colnames(cold)[1:2]=c("array_row","array_col")
    colnames(cold)[4]="sample_id"
    colnames(cold)[3]="z_type"
    spe3<- SpatialExperiment(
      assay = list(counts = matrixlist[[3]]),
      colData = cold,
      rowData = paste("gene",1:length(rownames(matrixlist[[3]])))
    )
    rownames(spe3)=rowData(spe3)$X
    
    
    #####筛选：
    for(i in seq_len(3)){
      spe_i <- eval(parse(text = paste0("spe", i)))
      spe_i <- scuttle::addPerCellQC(spe_i,)
      spe_i <- spe_i[, !(colData(spe_i)$sum < 10 |            
                           colData(spe_i)$detected < 10)]  # library size/number of expressed genes
      # Select QC threshold for lowly expressed genes: at least 20 non-zero spots:
      qc_low_gene <- rowSums(assays(spe_i)$counts > 0) >= 20
      # Remove lowly abundant genes
      spe_i <- spe_i[qc_low_gene,]
      assign(paste0("spe", i), spe_i)
      message("Dimension of spe", i, ": ", dim(spe_i)[1], ", ", dim(spe_i)[2])
    }
    
    # find vector of common genes across all samples:
    a <- rownames(counts(spe1)); 
    b <- rownames(counts(spe2)); 
    c <- rownames(counts(spe3))
    CommonGene <- Reduce(intersect, list(a,b,c))
    spe1 <- spe1[CommonGene,]
    spe2 <- spe2[CommonGene,]
    spe3 <- spe3[CommonGene,]
    
    spe.combined =cbind(spe1,spe2,spe3,deparse.level = 1)
    multi_results <- DESpace_test(spe=spe.combined,spatial_cluster="z_type",sample_col = "sample_id",replicates = TRUE)
    result= multi_results$gene_results
    id <- result$gene_id
    padj <- result$PValue
    target_order <- paste("gene",1:length(rownames(matrixlist[[3]])))
    
    p_value=padj
    padj[padj<=0.05] <- 0
    padj[padj>0.05] <- 1
    padj=1-padj
    result_value=padj
    despacegenename=id[padj==1]
    index=match(despacegenename,target_order)
    despacesvgene=genename[index]
    end=Sys.time()
    time_value=as.numeric((end-begin), units = "mins")
    result=list(result_value,despacesvgene,time_value,p_value,multi_results$gene_results)
    result_total[[6]][[1]]=result
  }
  save(result_total,file=paste("result_other_",dataname,".RData"))
}

