          calpha.list = c_alpha_global,
          g = g,
          result = result_ctig_global,
          model_type = "nb"
        )
        
        result_zinb <- MODEL_CHECKING(
          spelist = spelist_global,
          calpha.list = c_alpha_global,
          g = g,
          result = result_ctig_global,
          model_type = "zinb"
        )
        
        one_gene_result <- lapply(4, function(gene_index) {
          res <- compare_models(
            result_nb = result_nb,
            result_zinb = result_zinb,
            spelist = spelist_global,
            calpha.list = c_alpha_global,
            g = g,
            result = result_ctig_global,
            gene_index = gene_index
          )
          return(res)
        })
        
        # 检查是否有组织结果全部为NULL（即全部失败）
        if(all(sapply(one_gene_result, is.null))) {
          cat(sprintf("警告: 基因 %d 的所有组织处理都失败\n", g))
          return(NULL)
        }
        
        cat(sprintf("基因 %d 处理完成\n", g))
        return(one_gene_result)
        
      }, error = function(e) {
        # 捕获错误但不中断
        message(paste("基因", g, "的MODEL_CHECKING失败:", e$message))
        return(NULL)
      })
    }, future.seed = TRUE)
    
    # 保存结果，包括NULL值以便追踪
    save(all_results, 
         file = paste0("/gemini/code/modelcheck/", 
                       (chunk_data[1]), "_", (chunk_data[length(chunk_data)]), 
                       "_model_checking_dlpfc34711_supple_",spa,".RData"))
    
    # 统计成功和失败的基因数
    success_count <- sum(!sapply(all_results, is.null))
    fail_count <- sum(sapply(all_results, is.null))
    
    cat(sprintf("批次完成: 成功 %d 个基因, 失败 %d 个基因\n", success_count, fail_count))
    
    # 如果有失败的，输出失败的基因索引
    if(fail_count > 0) {
      failed_indices <- which(sapply(all_results, is.null))
      cat("失败的基因索引:", chunk_data[failed_indices], "\n")
    }
  }
}
    
    
    
    

