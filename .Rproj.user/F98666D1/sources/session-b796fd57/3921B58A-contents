count_significant <- function(all_result_lr_voung, alpha = 0.05) {
  # 获取列表长度
  n_elements <- length(all_result_lr_voung)
  
  # 初始化结果矩阵 (4x4)
  count_matrix <- matrix(0, nrow = 4, ncol = 4)
  rownames(count_matrix)=paste("section",1:4)
  colnames(count_matrix)=c("nb_lr","nb_vuong","linear_lr","linear_vuong")
  
  # 遍历所有元素
  for (i in seq_len(n_elements)) {
    current_element <- all_result_lr_voung[[i]]
    
    # 检查当前元素是否有4个列表
    if (length(current_element) == 4) {
      # 遍历4个列表
      for (j in 1:4) {
        current_vector <- current_element[[j]]
        
        # 检查当前向量是否是4维
        if (length(current_vector) == 4) {
          # 统计小于alpha的个数并累加
          count_matrix[j, ] <- count_matrix[j, ] + (current_vector < alpha)
        }
      }
    }
  }
  
  return(count_matrix)
}

